generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                           String                       @id @default(uuid())
  name                         String
  email                        String                       @unique
  passwordHash                 String
  role                         UserRole
  isActive                     Boolean                      @default(true)
  createdAt                    DateTime                     @default(now())
  updatedAt                    DateTime                     @updatedAt
  mustChangePassword           Boolean                      @default(false)
  isAdmin                      Boolean                      @default(false)
  /// * Chaves dos tutoriais já concluídos pelo usuário (ex.: student-dashboard-tutorial-done).
  completedTutorialKeys        String[]                     @default([])
  auditLogs                    AuditLog[]                   @relation("UserAuditLogs")
  coordinatorReportsFrom       CoordinatorReport[]          @relation("CoordinatorReportFrom")
  coordinatorReportMessages    CoordinatorReportMessage[]   @relation("CoordinatorReportMessageAuthor")
  lessonLastEdited             CourseLesson[]               @relation("LessonLastEditedBy")
  emailCampaignsCanceled       EmailCampaign[]              @relation("EmailCampaignCanceledBy")
  emailCampaignsConfirmed      EmailCampaign[]              @relation("EmailCampaignConfirmedBy")
  emailCampaignsCreated        EmailCampaign[]              @relation("EmailCampaignCreatedBy")
  emailTemplatesCreated        EmailTemplate[]              @relation("EmailTemplateCreatedBy")
  legalDocumentVersionsCreated LegalDocumentVersion[]       @relation("LegalDocumentVersionCreatedBy")
  lessonQuestionStaffReplies   LessonQuestionTeacherReply[] @relation("LessonQuestionStaffReply")
  onboardingGuidesUpdated      OnboardingGuide[]            @relation("OnboardingGuideUpdatedBy")
  onboardingVisits             OnboardingUserVisit?
  pendingSiteChangesRequested  PendingSiteChange[]
  pendingSiteChangesReviewed   PendingSiteChange[]          @relation("PendingSiteChangeReviewedBy")
  pendingTestimonialsReviewed  PendingTestimonial[]         @relation("PendingTestimonialReviewedBy")
  platformExperienceFeedbacks  PlatformExperienceFeedback[]
  sentEmails                   SentEmail[]                  @relation("SentEmailPerformedBy")
  smsCampaignsCanceled         SmsCampaign[]                @relation("SmsCampaignCanceledBy")
  smsCampaignsConfirmed        SmsCampaign[]                @relation("SmsCampaignConfirmedBy")
  smsCampaignsCreated          SmsCampaign[]                @relation("SmsCampaignCreatedBy")
  smsTemplatesCreated          SmsTemplate[]                @relation("SmsTemplateCreatedBy")
  studentsDeleted              Student[]                    @relation("StudentDeletedBy")
  student                      Student?
  studentAttachments           StudentAttachment[]          @relation("StudentAttachmentUploadedBy")
  supportTickets               SupportTicket[]
  teacher                      Teacher?
  accessLogs                   UserAccessLog[]
  legalAcceptance              UserLegalAcceptance?
  notifications                UserNotification[]
  pageVisits                   UserPageVisit[]
  verificationTokens           VerificationToken[]
  siteQrCodesCreated           SiteQrCode[]                 @relation("SiteQrCodeCreatedBy")
  marketingCampaignResponses       MarketingCampaignResponse[]
  marketingCampaignResponseLikes   MarketingCampaignResponseLike[]
}

/// * Navegação na área logada — rota (pathname) por utilizador, para o Master acompanhar páginas vistas.
model UserPageVisit {
  id        String   @id @default(uuid())
  userId    String
  /// * Caminho da rota (ex.: /dashboard), sem query string.
  path      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

/// * Login com sucesso — histórico para o Master (IP/User-Agent conforme cabeçalhos do proxy).
model UserAccessLog {
  id        String   @id @default(uuid())
  userId    String
  createdAt DateTime @default(now())
  ipAddress String?
  userAgent String?
  /// * EMAIL ou CPF (mesmo campo `kind` do formulário de login).
  loginKind String   @default("EMAIL")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

model UserNotification {
  id        String               @id @default(uuid())
  userId    String
  kind      UserNotificationKind
  title     String
  body      String?
  linkUrl   String?
  readAt    DateTime?
  /// * Chave única para não repetir o mesmo evento (ex.: mesma aula liberada).
  dedupeKey String               @unique
  createdAt DateTime             @default(now())
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt(sort: Desc)])
}

model LegalDocumentVersion {
  id                 String                @id @default(uuid())
  kind               LegalDocumentKind
  /// * Rótulo de versão exibido ao usuário (ex.: 1.0, 2025-03). Único por tipo de documento.
  versionLabel       String
  title              String                @default("")
  contentRich        String
  status             LegalDocumentStatus   @default(DRAFT)
  publishedAt        DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  createdByUserId    String?
  createdBy          User?                 @relation("LegalDocumentVersionCreatedBy", fields: [createdByUserId], references: [id])
  cookieAcceptances  UserLegalAcceptance[] @relation("AcceptanceCookie")
  privacyAcceptances UserLegalAcceptance[] @relation("AcceptancePrivacy")
  termsAcceptances   UserLegalAcceptance[] @relation("AcceptanceTerms")

  @@unique([kind, versionLabel])
  @@index([kind, status])
}

/// * Registro por usuário logado das versões publicadas aceitas (para não reexibir o banner).
model UserLegalAcceptance {
  id               String                @id @default(uuid())
  userId           String                @unique
  termsVersionId   String?
  privacyVersionId String?
  cookieVersionId  String?
  acceptedAt       DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  cookieVersion    LegalDocumentVersion? @relation("AcceptanceCookie", fields: [cookieVersionId], references: [id])
  privacyVersion   LegalDocumentVersion? @relation("AcceptancePrivacy", fields: [privacyVersionId], references: [id])
  termsVersion     LegalDocumentVersion? @relation("AcceptanceTerms", fields: [termsVersionId], references: [id])
  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// * Conteúdo de onboarding por perfil (rich text), editável por Master/Admin.
model OnboardingGuide {
  id          String   @id @default(uuid())
  role        UserRole @unique
  title       String   @default("")
  contentRich String
  updatedAt   DateTime @updatedAt
  updatedById String?
  updatedBy   User?    @relation("OnboardingGuideUpdatedBy", fields: [updatedById], references: [id])
}

/// * Registro de acesso à página de onboarding (feedback para administradores).
model OnboardingUserVisit {
  id          String   @id @default(uuid())
  userId      String   @unique
  role        UserRole
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  viewCount   Int      @default(1)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lastSeenAt])
}

/// * Avaliação da experiência do aluno (plataforma, aulas, professor, comentário e indicação).
model PlatformExperienceFeedback {
  id              String   @id @default(uuid())
  userId          String
  /// * Texto livre: quem indicaria, contato, etc.
  referral        String?
  createdAt       DateTime @default(now())
  /// * Nota de 1 a 10 — plataforma (navegação, uso geral).
  ratingPlatform  Int
  /// * Nota de 1 a 10 — aulas e conteúdo.
  ratingLessons   Int
  /// * Nota de 1 a 10 — atuação do(s) professor(es).
  ratingTeacher   Int
  /// * Comentário opcional sobre a plataforma.
  commentPlatform String?
  commentLessons  String?
  commentTeacher  String?
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

/// * Campanha de marketing / pesquisa (ex.: Dia das Mães).
model MarketingCampaign {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  description String?
  isActive    Boolean  @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  responses MarketingCampaignResponse[]

  @@index([isActive])
  @@index([startsAt])
  @@index([endsAt])
}

/// * Resposta do usuário para uma campanha (nota + comentário).
model MarketingCampaignResponse {
  id          String   @id @default(uuid())
  campaignId  String
  userId      String
  ratingStars Int
  comment     String?
  createdAt   DateTime @default(now())

  campaign MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes    MarketingCampaignResponseLike[]

  @@index([campaignId])
  @@index([userId])
  @@index([createdAt])
  @@unique([campaignId, userId])
}

/// * Curtida de um aluno em uma declaração de outro aluno na mesma campanha (uma por par usuário×resposta).
model MarketingCampaignResponseLike {
  id         String   @id @default(uuid())
  responseId String
  userId     String
  createdAt  DateTime @default(now())

  response MarketingCampaignResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  user     User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([responseId, userId])
  @@index([responseId])
  @@index([userId])
}

model SentEmail {
  id                String   @id @default(uuid())
  to                String
  subject           String
  messageId         String?
  emailType         String
  entityType        String?
  entityId          String?
  sentAt            DateTime @default(now())
  performedByUserId String?
  performedByUser   User?    @relation("SentEmailPerformedBy", fields: [performedByUserId], references: [id])
}

model VerificationToken {
  id           String                @id @default(cuid())
  userId       String
  studentId    String?
  enrollmentId String?
  type         VerificationTokenType
  tokenHash    String
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime              @default(now())
  enrollment   Enrollment?           @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  student      Student?              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Teacher {
  id                    String                       @id @default(uuid())
  name                  String
  phone                 String?
  email                 String?
  isActive              Boolean                      @default(true)
  deletedAt             DateTime?
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt
  userId                String?                      @unique
  photoUrl              String?
  classGroups           ClassGroup[]
  lessonQuestionReplies LessonQuestionTeacherReply[]
  user                  User?                        @relation(fields: [userId], references: [id])
}

model Course {
  id             String                @id @default(uuid())
  name           String                @unique
  description    String?
  workloadHours  Int?
  status         CourseStatus          @default(ACTIVE)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  content        String?
  imageUrl       String?
  slug           String                @unique
  classGroups    ClassGroup[]
  modules        CourseModule[]
  siteFormations SiteFormationCourse[]
}

model CourseModule {
  id          String         @id @default(uuid())
  courseId    String
  title       String
  description String?
  order       Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  lessons     CourseLesson[]
  course      Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, order])
}

model CourseLesson {
  id                 String                     @id @default(uuid())
  moduleId           String
  title              String
  order              Int                        @default(0)
  durationMinutes    Int?
  contentRich        String?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  videoUrl           String?
  imageUrls          String[]                   @default([])
  /// * URL do PDF da aula (material complementar).
  pdfUrl             String?
  /// * URLs dos arquivos de apoio da aula (material complementar).
  attachmentUrls     String[]                   @default([])
  /// * Resumo rápido da aula: o que será aprendido (exibido no topo para o aluno).
  summary            String?
  /// * Última edição: usuário que alterou o conteúdo (para auditoria pelo master).
  lastEditedByUserId String?
  lastEditedAt       DateTime?
  /// * Nomes exibidos para cada URL (mesmo índice que attachmentUrls).
  attachmentNames    String[]                   @default([])
  classSessions      ClassSession[]
  lastEditedByUser   User?                      @relation("LessonLastEditedBy", fields: [lastEditedByUserId], references: [id])
  module             CourseModule               @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  exercises          CourseLessonExercise[]
  lessonFavorites    EnrollmentLessonFavorite[]
  lessonNotes        EnrollmentLessonNote[]
  lessonPassages     EnrollmentLessonPassage[]
  lessonProgress     EnrollmentLessonProgress[]

  @@unique([moduleId, order])
}

/// * Exercício de múltipla escolha vinculado à aula.
model CourseLessonExercise {
  id        String                           @id @default(uuid())
  lessonId  String
  order     Int                              @default(0)
  question  String
  createdAt DateTime                         @default(now())
  updatedAt DateTime                         @updatedAt
  lesson    CourseLesson                     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  options   CourseLessonExerciseOption[]
  answers   EnrollmentLessonExerciseAnswer[]

  @@index([lessonId])
}

/// * Opção de resposta de um exercício de múltipla escolha.
model CourseLessonExerciseOption {
  id         String               @id @default(uuid())
  exerciseId String
  order      Int                  @default(0)
  text       String
  isCorrect  Boolean              @default(false)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  exercise   CourseLessonExercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([exerciseId])
}

model ClassGroup {
  id               String           @id @default(uuid())
  courseId         String
  teacherId        String
  daysOfWeek       String[]
  startTime        String
  endTime          String
  capacity         Int
  status           ClassGroupStatus @default(PLANEJADA)
  location         String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  endDate          DateTime?        @db.Date
  startDate        DateTime         @db.Date
  preventAutoClose Boolean          @default(false)
  course           Course           @relation(fields: [courseId], references: [id])
  teacher          Teacher          @relation(fields: [teacherId], references: [id])
  sessions         ClassSession[]
  enrollments      Enrollment[]
}

model ClassSession {
  id                 String              @id @default(uuid())
  classGroupId       String
  sessionDate        DateTime            @db.Date
  startTime          String
  endTime            String
  status             ClassSessionStatus  @default(SCHEDULED)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  lessonId           String?
  classGroup         ClassGroup          @relation(fields: [classGroupId], references: [id])
  lesson             CourseLesson?       @relation(fields: [lessonId], references: [id])
  sessionAttendances SessionAttendance[]

  @@unique([classGroupId, sessionDate])
}

/// * Frequência do aluno em uma sessão de aula (professor marca presença).
model SessionAttendance {
  id                   String       @id @default(uuid())
  classSessionId       String
  enrollmentId         String
  present              Boolean      @default(false)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  /// * Justificativa informada pelo professor quando o aluno está ausente (opcional).
  absenceJustification String?
  classSession         ClassSession @relation(fields: [classSessionId], references: [id], onDelete: Cascade)
  enrollment           Enrollment   @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@unique([classSessionId, enrollmentId])
  @@index([classSessionId])
  @@index([enrollmentId])
}

model TimeSlot {
  id        String   @id @default(uuid())
  startTime String
  endTime   String
  name      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Holiday {
  id             String   @id @default(uuid())
  date           DateTime @db.Date
  name           String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  recurring      Boolean  @default(false)
  /// * Se preenchidos (HH:mm), é evento: só turmas cujo horário cruza este intervalo são adiadas neste dia.
  eventStartTime String?
  eventEndTime   String?
}

model AuditLog {
  id                String   @id @default(uuid())
  entityType        String
  entityId          String
  action            String
  diffJson          String
  performedByUserId String?
  createdAt         DateTime @default(now())
  performedByUser   User?    @relation("UserAuditLogs", fields: [performedByUserId], references: [id])
}

model Student {
  id                    String              @id @default(uuid())
  name                  String
  birthDate             DateTime            @db.Date
  cpf                   String              @unique
  rg                    String
  phone                 String
  gender                Gender
  hasDisability         Boolean             @default(false)
  disabilityDescription String?
  educationLevel        EducationLevel
  isStudying            Boolean             @default(false)
  studyShift            StudyShift?
  guardianName          String?
  guardianCpf           String?
  guardianRg            String?
  guardianPhone         String?
  guardianRelationship  String?
  deletedAt             DateTime?
  deletedByUserId       String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  city                  String              @default("Belém")
  complement            String?
  neighborhood          String              @default("")
  number                String              @default("")
  state                 String              @default("PA")
  street                String              @default("")
  email                 String?
  cep                   String?
  userId                String?             @unique
  enrollments           Enrollment[]
  deletedByUser         User?               @relation("StudentDeletedBy", fields: [deletedByUserId], references: [id])
  user                  User?               @relation(fields: [userId], references: [id])
  attachments           StudentAttachment[]
  verificationTokens    VerificationToken[]
}

model Enrollment {
  id                    String                           @id @default(uuid())
  studentId             String
  classGroupId          String
  enrolledAt            DateTime                         @default(now())
  status                String                           @default("ACTIVE")
  enrollmentConfirmedAt DateTime?
  termsAcceptedAt       DateTime?
  termsVersion          String?
  confirmationMethod    String?
  confirmedIp           String?
  createdAt             DateTime                         @default(now())
  updatedAt             DateTime                         @updatedAt
  certificateUrl        String?
  certificatePublicId   String?
  certificateFileName   String?
  isPreEnrollment       Boolean                          @default(false)
  classGroup            ClassGroup                       @relation(fields: [classGroupId], references: [id], onDelete: Cascade)
  student               Student                          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  exerciseAnswers       EnrollmentLessonExerciseAnswer[]
  lessonFavorites       EnrollmentLessonFavorite[]
  lessonNotes           EnrollmentLessonNote[]
  lessonPassages        EnrollmentLessonPassage[]
  lessonProgress        EnrollmentLessonProgress[]
  lessonQuestions       EnrollmentLessonQuestion[]
  questionReplies       EnrollmentLessonQuestionReply[]
  sessionAttendances    SessionAttendance[]
  verificationTokens    VerificationToken[]
}

model EnrollmentLessonFavorite {
  id           String       @id @default(uuid())
  enrollmentId String
  lessonId     String
  createdAt    DateTime     @default(now())
  enrollment   Enrollment   @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson       CourseLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId])
}

model EnrollmentLessonNote {
  id                 String       @id @default(uuid())
  enrollmentId       String
  lessonId           String
  content            String
  videoTimestampSecs Int?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  enrollment         Enrollment   @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson             CourseLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([enrollmentId, lessonId])
}

model EnrollmentLessonPassage {
  id           String       @id @default(uuid())
  enrollmentId String
  lessonId     String
  text         String
  startOffset  Int
  createdAt    DateTime     @default(now())
  enrollment   Enrollment   @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson       CourseLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([enrollmentId, lessonId])
}

model EnrollmentLessonProgress {
  id                   String       @id @default(uuid())
  enrollmentId         String
  lessonId             String
  completed            Boolean      @default(false)
  percentWatched       Int          @default(0)
  percentRead          Int          @default(0)
  completedAt          DateTime?
  updatedAt            DateTime     @updatedAt
  lastAccessedAt       DateTime?
  totalMinutesStudied  Int          @default(0)
  /// * Último slide (índice 0-based) visualizado; null = não definido ou concluiu o último.
  lastContentPageIndex Int?
  enrollment           Enrollment   @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson               CourseLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId])
}

/// * Dúvida ou comentário do aluno sobre a aula (fórum por aula).
model EnrollmentLessonQuestion {
  id             String                          @id @default(uuid())
  enrollmentId   String
  lessonId       String
  content        String
  createdAt      DateTime                        @default(now())
  updatedAt      DateTime                        @updatedAt
  enrollment     Enrollment                      @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  replies        EnrollmentLessonQuestionReply[]
  teacherReplies LessonQuestionTeacherReply[]

  @@index([enrollmentId, lessonId])
  @@index([lessonId])
}

/// * Resposta oficial do professor ou da equipe (admin/master) a uma dúvida na aula.
model LessonQuestionTeacherReply {
  id          String                   @id @default(uuid())
  questionId  String
  /// * Professor do curso (mutuamente exclusivo com staffUserId em regra de negócio).
  teacherId   String?
  content     String
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  /// * Admin/Master que respondeu no fórum (alternativa a teacherId).
  staffUserId String?
  question    EnrollmentLessonQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  staffUser   User?                    @relation("LessonQuestionStaffReply", fields: [staffUserId], references: [id])
  teacher     Teacher?                 @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@index([teacherId])
  @@index([staffUserId])
}

/// * Resposta de um aluno ao comentário/dúvida de outro (em "Dúvidas sobre esta aula").
model EnrollmentLessonQuestionReply {
  id           String                   @id @default(uuid())
  questionId   String
  enrollmentId String
  content      String
  createdAt    DateTime                 @default(now())
  enrollment   Enrollment               @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  question     EnrollmentLessonQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@index([enrollmentId])
}

/// * Resposta do aluno a um exercício de múltipla escolha (várias tentativas por exercício; usa-se a mais recente para exibir).
model EnrollmentLessonExerciseAnswer {
  id               String               @id @default(uuid())
  enrollmentId     String
  exerciseId       String
  selectedOptionId String
  correct          Boolean
  createdAt        DateTime             @default(now())
  enrollment       Enrollment           @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  exercise         CourseLessonExercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([enrollmentId, exerciseId, createdAt])
  @@index([enrollmentId, exerciseId, createdAt], map: "EnrollmentLessonExerciseAnswer_enrollmentId_exerciseId_createdA")
}

model StudentAttachment {
  id               String         @id @default(cuid())
  studentId        String
  type             AttachmentType
  fileName         String?
  mimeType         String?
  sizeBytes        Int?
  publicId         String
  url              String
  createdAt        DateTime       @default(now())
  uploadedByUserId String?
  deletedAt        DateTime?
  student          Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  uploadedByUser   User?          @relation("StudentAttachmentUploadedBy", fields: [uploadedByUserId], references: [id])

  @@index([studentId, type])
}

model SiteSettings {
  id                    String   @id @default(uuid())
  siteName              String?
  logoUrl               String?
  faviconUrl            String?
  primaryColor          String?
  secondaryColor        String?
  contactEmail          String?
  contactPhone          String?
  contactWhatsapp       String?
  businessHours         String?
  socialInstagram       String?
  socialFacebook        String?
  socialYoutube         String?
  socialLinkedin        String?
  seoTitleDefault       String?
  seoDescriptionDefault String?
  updatedAt             DateTime @updatedAt
  addresses             Json?
