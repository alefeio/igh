/// * Chamado de suporte do aluno (área logada).
model SupportTicket {
  id                String                 @id @default(uuid())
  userId            String
  protocolNumber    String                 @unique
  subject           String
  summary           String
  status            SupportTicketStatus    @default(OPEN)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  attachmentUrls    String[]               @default([])
  attachmentNames   String[]               @default([])
  /// * Quando o aluno (dono) abriu o chamado pela última vez; usado para "não lido".
  studentLastReadAt DateTime?
  user              User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages          SupportTicketMessage[]
}

/// * Mensagem de um chamado (aluno ou suporte).
model SupportTicketMessage {
  id            String        @id @default(uuid())
  ticketId      String
  authorUserId  String
  isFromSupport Boolean       @default(false)
  content       String
  createdAt     DateTime      @default(now())
  ticket        SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

/// * Reporte de professor/admin/master à coordenação (comunicação + anexos).
model CoordinatorReport {
  id                  String                     @id @default(uuid())
  protocolNumber      String                     @unique
  fromUserId          String
  subject             String
  summary             String
  status              CoordinatorReportStatus    @default(OPEN)
  attachmentUrls      String[]                   @default([])
  attachmentNames     String[]                   @default([])
  unreadByCoordinator Boolean                    @default(true)
  unreadByReporter    Boolean                    @default(false)
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  fromUser            User                       @relation("CoordinatorReportFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  messages            CoordinatorReportMessage[]

  @@index([fromUserId])
  @@index([updatedAt])
}

model CoordinatorReportMessage {
  id                String            @id @default(uuid())
  reportId          String
  authorUserId      String
  isFromCoordinator Boolean           @default(false)
  content           String
  attachmentUrls    String[]          @default([])
  attachmentNames   String[]          @default([])
  createdAt         DateTime          @default(now())
  author            User              @relation("CoordinatorReportMessageAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)
  report            CoordinatorReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
}

