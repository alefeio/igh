generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                          String              @id @default(uuid())
  name                        String
  email                       String              @unique
  passwordHash                String
  role                        UserRole
  isActive                    Boolean             @default(true)
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt
  mustChangePassword          Boolean             @default(false)
  isAdmin                     Boolean             @default(false)
  auditLogs                   AuditLog[]          @relation("UserAuditLogs")
  pendingSiteChangesRequested PendingSiteChange[]
  pendingSiteChangesReviewed  PendingSiteChange[] @relation("PendingSiteChangeReviewedBy")
  sentEmails                  SentEmail[]         @relation("SentEmailPerformedBy")
  studentsDeleted             Student[]           @relation("StudentDeletedBy")
  student                     Student?
  studentAttachments          StudentAttachment[] @relation("StudentAttachmentUploadedBy")
  teacher                     Teacher?
  verificationTokens          VerificationToken[]
}

model SentEmail {
  id                String   @id @default(uuid())
  to                String
  subject           String
  messageId         String?
  emailType         String
  entityType        String?
  entityId          String?
  sentAt            DateTime @default(now())
  performedByUserId String?
  performedByUser   User?    @relation("SentEmailPerformedBy", fields: [performedByUserId], references: [id])
}

model VerificationToken {
  id           String                @id @default(cuid())
  userId       String
  studentId    String?
  enrollmentId String?
  type         VerificationTokenType
  tokenHash    String
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime              @default(now())
  enrollment   Enrollment?           @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  student      Student?              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Teacher {
  id          String       @id @default(uuid())
  name        String
  phone       String?
  email       String?
  isActive    Boolean      @default(true)
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  userId      String?      @unique
  classGroups ClassGroup[]
  user        User?        @relation(fields: [userId], references: [id])
}

model Course {
  id             String                @id @default(uuid())
  name           String                @unique
  description    String?
  workloadHours  Int?
  status         CourseStatus          @default(ACTIVE)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  content        String?
  imageUrl       String?
  slug           String                @unique
  classGroups    ClassGroup[]
  modules        CourseModule[]
  siteFormations SiteFormationCourse[]
}

model CourseModule {
  id          String         @id @default(uuid())
  courseId    String
  title       String
  description String?
  order       Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  lessons     CourseLesson[]
  course      Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, order])
}

model CourseLesson {
  id              String       @id @default(uuid())
  moduleId        String
  title           String
  order           Int          @default(0)
  durationMinutes Int?
  contentRich     String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  module          CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([moduleId, order])
}

model ClassGroup {
  id               String           @id @default(uuid())
  courseId         String
  teacherId        String
  daysOfWeek       String[]
  startTime        String
  endTime          String
  capacity         Int
  status           ClassGroupStatus @default(PLANEJADA)
  location         String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  endDate          DateTime?        @db.Date
  startDate        DateTime         @db.Date
  preventAutoClose Boolean          @default(false)
  course           Course           @relation(fields: [courseId], references: [id])
  teacher          Teacher          @relation(fields: [teacherId], references: [id])
  sessions         ClassSession[]
  enrollments      Enrollment[]
}

model ClassSession {
  id           String             @id @default(uuid())
  classGroupId String
  sessionDate  DateTime           @db.Date
  startTime    String
  endTime      String
  status       ClassSessionStatus @default(SCHEDULED)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  classGroup   ClassGroup         @relation(fields: [classGroupId], references: [id])

  @@unique([classGroupId, sessionDate])
}

model TimeSlot {
  id        String   @id @default(uuid())
  startTime String
  endTime   String
  name      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Holiday {
  id        String   @id @default(uuid())
  date      DateTime @db.Date
  name      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  recurring Boolean  @default(false)
}

model AuditLog {
  id                String   @id @default(uuid())
  entityType        String
  entityId          String
  action            String
  diffJson          String
  performedByUserId String?
  createdAt         DateTime @default(now())
  performedByUser   User?    @relation("UserAuditLogs", fields: [performedByUserId], references: [id])
}

model Student {
  id                    String              @id @default(uuid())
  name                  String
  birthDate             DateTime            @db.Date
  cpf                   String              @unique
  rg                    String
  phone                 String
  gender                Gender
  hasDisability         Boolean             @default(false)
  disabilityDescription String?
  educationLevel        EducationLevel
  isStudying            Boolean             @default(false)
  studyShift            StudyShift?
  guardianName          String?
  guardianCpf           String?
  guardianRg            String?
  guardianPhone         String?
  guardianRelationship  String?
  deletedAt             DateTime?
  deletedByUserId       String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  city                  String              @default("Belém")
  complement            String?
  neighborhood          String              @default("")
  number                String              @default("")
  state                 String              @default("PA")
  street                String              @default("")
  email                 String?
  cep                   String?
  userId                String?             @unique
  enrollments           Enrollment[]
  deletedByUser         User?               @relation("StudentDeletedBy", fields: [deletedByUserId], references: [id])
  user                  User?               @relation(fields: [userId], references: [id])
  attachments           StudentAttachment[]
  verificationTokens    VerificationToken[]
}

model Enrollment {
  id                    String              @id @default(uuid())
  studentId             String
  classGroupId          String
  enrolledAt            DateTime            @default(now())
  status                String              @default("ACTIVE")
  enrollmentConfirmedAt DateTime?
  termsAcceptedAt       DateTime?
  termsVersion          String?
  confirmationMethod    String?
  confirmedIp           String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  certificateUrl        String?
  certificatePublicId   String?
  certificateFileName   String?
  isPreEnrollment       Boolean             @default(false)
  classGroup            ClassGroup          @relation(fields: [classGroupId], references: [id], onDelete: Cascade)
  student               Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  verificationTokens    VerificationToken[]
}

model StudentAttachment {
  id               String         @id @default(cuid())
  studentId        String
  type             AttachmentType
  fileName         String?
  mimeType         String?
  sizeBytes        Int?
  publicId         String
  url              String
  createdAt        DateTime       @default(now())
  uploadedByUserId String?
  deletedAt        DateTime?
  student          Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  uploadedByUser   User?          @relation("StudentAttachmentUploadedBy", fields: [uploadedByUserId], references: [id])

  @@index([studentId, type])
}

model SiteSettings {
  id                    String   @id @default(uuid())
  siteName              String?
  logoUrl               String?
  faviconUrl            String?
  primaryColor          String?
  secondaryColor        String?
  contactEmail          String?
  contactPhone          String?
  contactWhatsapp       String?
  businessHours         String?
  socialInstagram       String?
  socialFacebook        String?
  socialYoutube         String?
  socialLinkedin        String?
  seoTitleDefault       String?
  seoDescriptionDefault String?
  updatedAt             DateTime @updatedAt
  addresses             Json?
}

model SiteAboutPage {
  id        String   @id @default(uuid())
  title     String?
  subtitle  String?
  content   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteMenuItem {
  id         String         @id @default(uuid())
  label      String
  href       String
  order      Int            @default(0)
  parentId   String?
  isExternal Boolean        @default(false)
  isVisible  Boolean        @default(true)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  parent     SiteMenuItem?  @relation("MenuItemsHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children   SiteMenuItem[] @relation("MenuItemsHierarchy")
}

model SiteBanner {
  id        String   @id @default(uuid())
  title     String?
  subtitle  String?
  ctaLabel  String?
  ctaHref   String?
  imageUrl  String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteFormation {
  id            String                @id @default(uuid())
  title         String
  slug          String                @unique
  summary       String?
  audience      String?
  outcomes      String[]              @default([])
  finalProject  String?
  prerequisites String?
  order         Int                   @default(0)
  isActive      Boolean               @default(true)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  courses       SiteFormationCourse[]
}

model SiteFormationCourse {
  formationId String
  courseId    String
  order       Int           @default(0)
  course      Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  formation   SiteFormation @relation(fields: [formationId], references: [id], onDelete: Cascade)

  @@id([formationId, courseId])
}

model SiteProject {
  id            String   @id @default(uuid())
  title         String
  slug          String   @unique
  summary       String?
  content       String?
  coverImageUrl String?
  galleryImages String[] @default([])
  order         Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SiteTestimonial {
  id            String   @id @default(uuid())
  name          String
  roleOrContext String?
  quote         String
  photoUrl      String?
  order         Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SitePartner {
  id         String   @id @default(uuid())
  name       String
  logoUrl    String?
  websiteUrl String?
  order      Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SiteNewsCategory {
  id       String         @id @default(uuid())
  name     String
  slug     String         @unique
  order    Int            @default(0)
  isActive Boolean        @default(true)
  posts    SiteNewsPost[]
}

model SiteNewsPost {
  id            String            @id @default(uuid())
  title         String
  slug          String            @unique
  excerpt       String?
  content       String?
  coverImageUrl String?
  categoryId    String?
  publishedAt   DateTime?
  isPublished   Boolean           @default(false)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  imageUrls     String[]          @default([])
  category      SiteNewsCategory? @relation(fields: [categoryId], references: [id])
}

model SiteFaqItem {
  id        String   @id @default(uuid())
  question  String
  answer    String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteTransparencyCategory {
  id        String                     @id @default(uuid())
  name      String
  slug      String                     @unique
  order     Int                        @default(0)
  isActive  Boolean                    @default(true)
  documents SiteTransparencyDocument[]
}

model SiteTransparencyDocument {
  id          String                   @id @default(uuid())
  categoryId  String
  title       String
  description String?
  date        DateTime?                @db.Date
  fileUrl     String?
  isActive    Boolean                  @default(true)
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  category    SiteTransparencyCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

model PendingSiteChange {
  id                String    @id @default(uuid())
  requestedByUserId String
  entityType        String
  action            String
  entityId          String?
  payload           Json
  status            String    @default("pending")
  reviewedByUserId  String?
  reviewedAt        DateTime?
  createdAt         DateTime  @default(now())
  requestedBy       User      @relation(fields: [requestedByUserId], references: [id], onDelete: Cascade)
  reviewedBy        User?     @relation("PendingSiteChangeReviewedBy", fields: [reviewedByUserId], references: [id])
}

enum VerificationTokenType {
  ENROLLMENT_CONFIRMATION
  FIRST_ACCESS
  PASSWORD_RESET
}

enum ClassSessionStatus {
  SCHEDULED
  CANCELED
}

enum UserRole {
  MASTER
  ADMIN
  TEACHER
  STUDENT
}

enum CourseStatus {
  ACTIVE
  INACTIVE
}

enum ClassGroupStatus {
  PLANEJADA
  ABERTA
  EM_ANDAMENTO
  ENCERRADA
  CANCELADA
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_SAY
}

enum StudyShift {
  MORNING
  AFTERNOON
  EVENING
  FULL
}

enum EducationLevel {
  NONE
  ELEMENTARY_INCOMPLETE
  ELEMENTARY_COMPLETE
  HIGH_INCOMPLETE
  HIGH_COMPLETE
  COLLEGE_INCOMPLETE
  COLLEGE_COMPLETE
  OTHER
}

enum AttachmentType {
  ID_DOCUMENT
  ADDRESS_PROOF
}
