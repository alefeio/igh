model SmsCampaign {
  id                     String                 @id @default(uuid())
  name                   String
  description            String?
  audienceType           SmsAudienceType
  audienceFilters        Json?
  templateId             String?
  messageContent         String?
  messageCharCount       Int?
  status                 SmsCampaignStatus      @default(DRAFT)
  totalFound             Int                    @default(0)
  totalValid             Int                    @default(0)
  totalMissingPhone      Int                    @default(0)
  totalInvalidPhone      Int                    @default(0)
  totalDuplicatesRemoved Int                    @default(0)
  totalSent              Int                    @default(0)
  totalDelivered         Int                    @default(0)
  totalFailed            Int                    @default(0)
  scheduledAt            DateTime?
  startedAt              DateTime?
  finishedAt             DateTime?
  createdById            String
  confirmedById          String?
  canceledById           String?
  canceledAt             DateTime?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  canceledBy             User?                  @relation("SmsCampaignCanceledBy", fields: [canceledById], references: [id])
  confirmedBy            User?                  @relation("SmsCampaignConfirmedBy", fields: [confirmedById], references: [id])
  createdBy              User                   @relation("SmsCampaignCreatedBy", fields: [createdById], references: [id])
  template               SmsTemplate?           @relation(fields: [templateId], references: [id])
  recipients             SmsCampaignRecipient[]

  @@index([status])
  @@index([createdById])
  @@index([scheduledAt])
}

model SmsCampaignRecipient {
  id                    String             @id @default(uuid())
  campaignId            String
  recipientType         String
  recipientId           String
  recipientNameSnapshot String
  phoneSnapshot         String
  phoneNormalized       String
  renderedMessage       String
  providerName          String?
  providerMessageId     String?
  providerResponse      Json?
  status                SmsRecipientStatus @default(PENDING)
  attempts              Int                @default(0)
  errorMessage          String?
  sentAt                DateTime?
  deliveredAt           DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  campaign              SmsCampaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([campaignId, status])
}

model SmsTemplate {
  id           String        @id @default(uuid())
  name         String
  description  String?
  categoryHint String?
  content      String
  active       Boolean       @default(true)
  createdById  String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  campaigns    SmsCampaign[]
  createdBy    User          @relation("SmsTemplateCreatedBy", fields: [createdById], references: [id])

  @@index([active])
}

model EmailCampaign {
  id                     String                   @id @default(uuid())
  name                   String
  description            String?
  audienceType           EmailAudienceType
  audienceFilters        Json?
  templateId             String?
  subject                String?
  htmlContent            String?
  textContent            String?
  status                 EmailCampaignStatus      @default(DRAFT)
  totalFound             Int                      @default(0)
  totalValid             Int                      @default(0)
  totalMissingEmail      Int                      @default(0)
  totalInvalidEmail      Int                      @default(0)
  totalDuplicatesRemoved Int                      @default(0)
  totalSent              Int                      @default(0)
  totalDelivered         Int                      @default(0)
  totalFailed            Int                      @default(0)
  totalOpened            Int                      @default(0)
  totalClicked           Int                      @default(0)
  scheduledAt            DateTime?
  startedAt              DateTime?
  finishedAt             DateTime?
  createdById            String
  confirmedById          String?
  canceledById           String?
  canceledAt             DateTime?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  /// * Rodadas de envio em massa (1ª execução, nova rodada após reenfileirar falhas, etc.).
  dispatchCount          Int                      @default(0)
  canceledBy             User?                    @relation("EmailCampaignCanceledBy", fields: [canceledById], references: [id])
  confirmedBy            User?                    @relation("EmailCampaignConfirmedBy", fields: [confirmedById], references: [id])
  createdBy              User                     @relation("EmailCampaignCreatedBy", fields: [createdById], references: [id])
  template               EmailTemplate?           @relation(fields: [templateId], references: [id])
  recipients             EmailCampaignRecipient[]

  @@index([status])
  @@index([createdById])
  @@index([scheduledAt])
}

model EmailCampaignRecipient {
  id                    String               @id @default(uuid())
  campaignId            String
  recipientType         String
  recipientId           String
  recipientNameSnapshot String
  emailSnapshot         String
  emailNormalized       String
  renderedSubject       String
  renderedHtmlContent   String?
  renderedTextContent   String?
  providerName          String?
  providerMessageId     String?
  providerResponse      Json?
  status                EmailRecipientStatus @default(PENDING)
  attempts              Int                  @default(0)
  errorMessage          String?
  sentAt                DateTime?
  deliveredAt           DateTime?
  openedAt              DateTime?
  clickedAt             DateTime?
  bouncedAt             DateTime?
  complainedAt          DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  campaign              EmailCampaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([campaignId, status])
}

model EmailTemplate {
  id              String          @id @default(uuid())
  name            String
  description     String?
  categoryHint    String?
  subjectTemplate String
  htmlContent     String?
  textContent     String?
  active          Boolean         @default(true)
  createdById     String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  campaigns       EmailCampaign[]
  createdBy       User            @relation("EmailTemplateCreatedBy", fields: [createdById], references: [id])

  @@index([active])
}

